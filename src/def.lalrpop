scanchain_pin: ScanChainPin = {
  <c:identifier> <p:identifier> => ScanChainPin { comp: c, pin: p },
}

scanchain_pin_list: Vec<ScanChainPin> = {
  <p:scanchain_pin> <mut l:scanchain_pin_list> => { l.push(p); l },
  <p:scanchain_pin> => vec![p],
}

scanchain_direction: ScanChainDirection = {
  "IN" => ScanChainDirection::IN,
  "OUT" => ScanChainDirection::OUT,
}

scanchain_commonpin: (ScanChainDirection, String) = {
  "(" <d:scanchain_direction> <p:identifier> ")" => (d, p),
}

scanchain_commonpin_list: Vec<(ScanChainDirection, String)> = {
  <c:scanchain_commonpin> <mut l:scanchain_commonpin_list> => { l.push(c); l },
  <c:scanchain_commonpin> => vec![c],
}

scanchain: ScanChain = {
  "-" <name:identifier> 
    "+" "START" <start:scanchain_pin>
    "+" "STOP" <stop:scanchain_pin>
    "+" "FLOATING" <fl:scanchain_pin_list>
    "+" "ORDERED" <ol:scanchain_pin_list>
    "+" "COMMONSCANPINS" <cpl:scanchain_commonpin_list>
    "+" "PARTITION" <part:identifier> "MAXBITS" <mb:integer> semicolon
    => ScanChain {
      name,
      start: Some(start),
      stop: Some(stop),
      floating: Some(fl),
      ordered: Some(ol),
      commonscanpins: Some(cpl),
      partition: Some((part, Some(mb))),
    },
  "-" <name:identifier> semicolon
    => ScanChain {
      name,
      start: None,
      stop: None,
      floating: None,
      ordered: None,
      commonscanpins: None,
      partition: None,
    },
}

scanchain_list: Vec<ScanChain> = {
  <s:scanchain> <mut l:scanchain_list> => { l.push(s); l },
  <s:scanchain> => vec![s],
}

scanchains: Vec<ScanChain> = {
  "SCANCHAINS" <n:integer> semicolon <sl:scanchain_list> "END" "SCANCHAINS" => sl,
}

