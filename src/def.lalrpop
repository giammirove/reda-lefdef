use std::str::FromStr;
use crate::common_handler::*;
use crate::def_handler::*;
use crate::vec_push;
use crate::set_opt;
use crate::panic_with_context;

grammar;

// Add this match block to control tokenization priority
match {
  // Comments
  r"#[^\n]*",
  // Whitespace
  r"\s+",
} else {
  // Keywords and literals (higher priority)
  "*",
  "(",
  ")",
  // Everything else
  _
}

