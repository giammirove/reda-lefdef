comp_source: ComponentSource = {
  "NETLIST" => ComponentSource::NETLIST,
  "DIST" => ComponentSource::DIST,
  "USER" => ComponentSource::USER,
  "TIMING" => ComponentSource::TIMING,
}

comp_placement: ComponentPlacement = {
  "PLACED" => ComponentPlacement::PLACED,
  "FIXED" => ComponentPlacement::FIXED,
  "COVER" => ComponentPlacement::COVER,
  "UNPLACED" => ComponentPlacement::UNPLACED,
}

comp_opts: ComponentOpts = {
  "+" "SOURCE" <s:comp_source> <mut o:comp_opts> => set_opt!(o,source,s),
  "+" "WEIGHT" <w:integer> <mut o:comp_opts> => set_opt!(o,weight,w),
  "+" "EEQMASTER" <e:identifier> <mut o:comp_opts> => set_opt!(o,eeq,e),
  "+" "REGION" <r:identifier> <mut o:comp_opts> => set_opt!(o,region,r),
  "+" <p:comp_placement> <pt:point> <or:orient> <mut o:comp_opts>
    => set_opt!(o,placement,(p, pt, or)),
  "+" "HALO" <l:integer> <b:integer> <r:integer> <t:integer> <mut o:comp_opts>
    => set_opt!(o,halo,(l, b, r, t)),
  "+" "ROUTEHALO" <d:integer> <mn:identifier> <mx:identifier> <mut o:comp_opts>
    => set_opt!(o,routehalo,(d, mn, mx)),
  "+" "MASKSHIFT" <m:integer> <mut o:comp_opts> => set_opt!(o,maskshift,m),
  "+" "PROPERTY" <pl:property+> <mut o:comp_opts>
    => set_opt!(o,properties,pl),
  () => ComponentOpts::default(),
}

component: Component = {
  "-" <name:identifier> <model:identifier> <opts:comp_opts> semicolon
    => Component::new(name, model, opts),
}

component_list: Vec<Component> = {
  <c:component> <mut l:component_list> => { l.push(c); l },
  <c:component> => vec![c],
}

components: Vec<Component> = {
  "COMPONENTS" <n:integer> semicolon <cl:component_list> "END" "COMPONENTS"
    => cl,
}

