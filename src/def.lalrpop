}

pin_use: PinUse = {
  "SIGNAL" => PinUse::SIGNAL,
  "POWER" => PinUse::POWER,
  "GROUND" => PinUse::GROUND,
  "CLOCK" => PinUse::CLOCK,
  "TIEOFF" => PinUse::TIEOFF,
  "ANALOG" => PinUse::ANALOG,
  "SCAN" => PinUse::SCAN,
  "RESET" => PinUse::RESET,
}

pin_placement: PinPlacement = {
  "PLACED" => PinPlacement::PLACED,
  "FIXED" => PinPlacement::FIXED,
  "COVER" => PinPlacement::COVER,
}

pin_port_body: PinPort = {
  "LAYER" <l:identifier> "MASK" <m:integer> <rl:rect_list>
    => PinPort { layer: Some(l), rects: Some(rl), polygons: None, vias: None, mask: Some(m) },
  "LAYER" <l:identifier> <rl:rect_list>
    => PinPort { layer: Some(l), rects: Some(rl), polygons: None, vias: None, mask: None },
  "POLYGON" <pl:polygon>
    => PinPort { layer: None, rects: None, polygons: Some(vec![pl]), vias: None, mask: None },
}

pin_port: PinPort = {
  "+" <p:pin_port_body> => p,
}

// TODO: find fix to allow multiple values 
pin_opt_port: PinOptsEnum = {
  "+" "PORT" <ppl:pin_port>
    => PinOptsEnum::Ports(vec![ppl]),
  <ppl:pin_port>
    => PinOptsEnum::Ports(vec![ppl]),
}

pin_opt: PinOptsEnum = {
  "+" "DIRECTION" <d:pin_direction>
    => PinOptsEnum::Direction(d),
  "+" "USE" <u:pin_use>
    => PinOptsEnum::Use(u),
  "+" "NETEXPR" <n:string>
    => PinOptsEnum::NetExpr(n),
  "+" "SUPPLYSENSITIVITY" <s:identifier>
    => PinOptsEnum::SupplySensitivity(s),
  "+" "GROUNDSENSITIVITY" <g:identifier>
    => PinOptsEnum::GroundSensitivity(g),
  "+" <p:pin_placement> <pt:point> <or:orient>
    => PinOptsEnum::Placement(PinOptPlacement::new(p, pt, or)),
  <ports:pin_opt_port> => ports,
  "+" "PROPERTY" <pl:property+>
    => PinOptsEnum::Properties(pl),
}

pin_opts: PinOpts = {
  <opts:pin_opt*> => {
    let mut o = PinOpts::default();
    for opt in opts {
      o.apply(opt);
    }
    o
  }
}

pin: Pin = {
  "-" <name:identifier> "+" "NET" <net:identifier> "+" "SPECIAL" <opts:pin_opts> semicolon
    => Pin::new(name, net, true, opts),
  "-" <name:identifier> "+" "NET" <net:identifier> <opts:pin_opts> semicolon
    => Pin::new(name, net, false, opts),
}

pins: Vec<Pin> = {
  "PINS" <n:integer> semicolon <pl:pin*> "END" "PINS" => pl,
}

////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  PINPROPERTIES Section                                                     //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

pinproperty: PinProperty = {
  "-" <comp:identifier> <pin:identifier> "+" "PROPERTY" <pl:property+> semicolon
    => PinProperty { comp_name: comp, pin_name: pin, properties: pl },
}

pinproperties: Vec<PinProperty> = {
  "PINPROPERTIES" <n:integer> semicolon <pl:pinproperty+> "END" "PINPROPERTIES" => pl,
}

