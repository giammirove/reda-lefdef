propdef_objtype: PropertyDefinitionObjectType = {
  "COMPONENT" => PropertyDefinitionObjectType::COMPONENT,
  "NET" => PropertyDefinitionObjectType::NET,
  "SPECIALNET" => PropertyDefinitionObjectType::SPECIALNET,
  "GROUP" => PropertyDefinitionObjectType::GROUP,
  "ROW" => PropertyDefinitionObjectType::ROW,
  "REGION" => PropertyDefinitionObjectType::REGION,
  "COMPONENTPIN" => PropertyDefinitionObjectType::COMPONENTPIN,
  "DESIGN" => PropertyDefinitionObjectType::DESIGN,
  "NONDEFAULTRULE" => PropertyDefinitionObjectType::NONDEFAULTRULE,
}

propdef_type: PropertyDefinitionType = {
  "INTEGER" => PropertyDefinitionType::INTEGER,
  "REAL" => PropertyDefinitionType::REAL,
  "STRING" => PropertyDefinitionType::STRING,
}

propdef_range_int: RangeOrValueEnum = {
  "RANGE" <min:integer> <max:integer> => RangeOrValueEnum::Integer(Some(Either::Left((min, max)))),
  integer => RangeOrValueEnum::Integer(Some(Either::Right(<>))),
}

propdef_range_real: RangeOrValueEnum = {
  "RANGE" <min:real> <max:real> => RangeOrValueEnum::Real(Some(Either::Left((min, max)))),
  real => RangeOrValueEnum::Real(Some(Either::Right(<>))),
}

propdef: PropertyDefinition = {
  <ot:propdef_objtype> <n:identifier> "INTEGER" <rv:propdef_range_int> semicolon
    => PropertyDefinition { object_type: ot, name: n, prop_type: PropertyDefinitionType::INTEGER, range_or_value: Some(rv) },
  <ot:propdef_objtype> <n:identifier> "INTEGER" semicolon
    => PropertyDefinition { object_type: ot, name: n, prop_type: PropertyDefinitionType::INTEGER, range_or_value: None },
  <ot:propdef_objtype> <n:identifier> "REAL" <rv:propdef_range_real> semicolon
    => PropertyDefinition { object_type: ot, name: n, prop_type: PropertyDefinitionType::REAL, range_or_value: Some(rv) },
  <ot:propdef_objtype> <n:identifier> "REAL" semicolon
    => PropertyDefinition { object_type: ot, name: n, prop_type: PropertyDefinitionType::REAL, range_or_value: None },
  <ot:propdef_objtype> <n:identifier> "STRING" <s:string> semicolon
    => PropertyDefinition { object_type: ot, name: n, prop_type: PropertyDefinitionType::STRING, range_or_value: Some(RangeOrValueEnum::String(Some(s))) },
  <ot:propdef_objtype> <n:identifier> "STRING" semicolon
    => PropertyDefinition { object_type: ot, name: n, prop_type: PropertyDefinitionType::STRING, range_or_value: None },
}

propdef_list: Vec<PropertyDefinition> = {
  <p:propdef> <mut l:propdef_list> => { l.push(p); l },
  <p:propdef> => vec![p],
}

propertydefinitions: Vec<PropertyDefinition> = {
  "PROPERTYDEFINITIONS" <pl:propdef_list> "END" "PROPERTYDEFINITIONS" => pl,
}

