tracks: Track = {
  "TRACKS" <d:track_dir> <start:integer> 
    "DO" <num:integer>
    "STEP" <step:integer> "MASK" <mask:integer> "SAMEMASK" 
    "LAYER" <ll:layer_list> semicolon
    => Track::new(d, start, num, step, ll, Some(mask), Some(true)),
  "TRACKS" <d:track_dir> <start:integer> "DO" <num:integer>
    "STEP" <step:integer> "MASK" <mask:integer> 
    "LAYER" <ll:layer_list> semicolon
    => Track::new(d, start, num, step, ll, Some(mask), Some(false)),
  "TRACKS" <d:track_dir> <start:integer> "DO" <num:integer>
    "STEP" <step:integer> "LAYER" <ll:layer_list> semicolon
    => Track::new(d, start, num, step, ll, None, None),
}

