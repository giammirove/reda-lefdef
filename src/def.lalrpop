////////////////////////////////////////////////////////////////////////////////

routing_via: RoutingVia = {
    <m:mask_no_semicolon?> <v:identifier> <o:orient?> 
    <dsb:do_step_by?>
    => RoutingVia {
        via_name: v,
        orient: o,
        mask: m,
        do_step_by: dsb,
    },
}

routing_point: RoutingPoint = {
    <p:point> <v:routing_via?> => RoutingPoint::new(p, v),

    // TODO: implement the rest
    // "MASK" <m:integer> <p:point> => RoutingPointItem::Point(p, Some(m)),
    // <p:point> => RoutingPointItem::Point(p, None),
}

routing_points: Vec<RoutingPoint> = {
    <p:routing_point+> => p,
}

