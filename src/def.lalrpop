via_rect: ViaRect = {
  "+" "RECT" <n:identifier> <r:rect> <m:mask_no_semicolon?> => ViaRect::new(n, r, m)
}

via_polygon: ViaPolygon = {
  "+" "POLYGON" <n:identifier> <m:mask_no_semicolon?> <p:polygon> => ViaPolygon::new(n,p,m),
}

via_layer: ViaLayer = {
  <vrl:via_rect> => ViaLayer::Rect(vrl),
  <vpl:via_polygon> => ViaLayer::Polygon(vpl),
}

via_rowcol: (i32, i32) = {
  "+" "ROWCOL" <rows:integer> <cols:integer> => (rows, cols)
}

via_origin: (i32, i32) = {
  "+" "ORIGIN" <ox:integer> <oy:integer> => (ox, oy)
}

via_offset: (i32, i32, i32, i32) = {
  "+" "OFFSET" <ob1:integer> <ob2:integer> <ot1:integer> <ot2:integer> => (ob1, ob2, ot1, ot2)
}

via_pattern: String = {
  "+" "PATTERN" <pat:via_pattern_cut> => pat
}

via: Via = {
  "-" <name:identifier> "+" "VIARULE" <vr:identifier>
    "+" "CUTSIZE" <cx:integer> <cy:integer>
    "+" "LAYERS" <bot:identifier> <cut:identifier> <top:identifier>
    "+" "CUTSPACING" <csx:integer> <csy:integer>
    "+" "ENCLOSURE" <eb1:integer> <eb2:integer> <et1:integer> <et2:integer>

    <rowcol:via_rowcol?>
    <origin:via_origin?>
    <offset:via_offset?>
    <pattern:via_pattern?>
    semicolon
    => Via {
      name,
      via_type: ViaType::ViaRule(ViaViaRule {
        name: vr,
        cutsize: (cx, cy),
        layers: (bot, cut, top),
        cutspacing: (csx, csy),
        enclosure: (eb1, eb2, et1, et2),
        rowcol,
        origin,
        offset,
        pattern,
      }),
    },
  "-" <name:identifier> <vll:via_layer*> semicolon
    => Via {
      name,
      via_type: ViaType::Geometry(vll),
    },
}

vias: Vec<Via> = {
  "VIAS" <n:integer> semicolon <vl:via*> "END" "VIAS" => vl,
}

