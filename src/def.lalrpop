point: Point = {
  "(" <x:integer> <y:integer> <e:integer?> ")" => Point::new(x, y, e),
  // TODO: what is * here?
  "(" pattern_match <y:integer> <e:integer?> ")" => Point::new(0, y, e),
  "(" <x:integer> pattern_match <e:integer?> ")" => Point::new(x, 0, e),
}

point_list: Vec<Point> = {
  <p:point+> => p,
}

rect: Rect = {
  "(" <x1:integer> <y1:integer> ")" "(" <x2:integer> <y2:integer> ")"
    => Rect::new(x1, y1, x2, y2),
}

rect_list: Vec<Rect> = {
  <r:rect> <mut l:rect_list> => { l.push(r); l },
  <r:rect> => vec![r],
}

polygon: Polygon = {
  <pl:point_list> => Polygon::new(pl),
}

property: Property = {
  <n:identifier> <v:value> => Property::new(n, v),
}

