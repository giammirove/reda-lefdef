//                                                                            //
//  BLOCKAGES Section                                                         //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

blockage_placement_component: String = {
  "COMPONENT" <c:identifier> => c,
}

blockage_placement_pushdown: bool = {
  "PUSHDOWN" => true, 
}

blockage_placement_type: BlockagePlacementType= {
  "SOFT" => BlockagePlacementType::SOFT, 
  "PARTIAL" <density:real> => BlockagePlacementType::PARTIAL(density), 
}

blockage_placement: BlockagePlacement = {
  "-" "PLACEMENT" <t:blockage_placement_type?>
    <p:blockage_placement_pushdown?> 
    <c:blockage_placement_component?> 
    "RECT" <rl:rect_list> semicolon
    => BlockagePlacement { component: c, pushdown: p, blockage_type: t, rects: rl },
}

blockage_routing: BlockageRouting = {
  "-" "LAYER" <l:identifier> "MASK" <m:integer> "SLOTS" <rl:rect_list> semicolon
    => BlockageRouting { layer: l, component: None, slots: Some(true), fills: None, pushdown: None, exceptpgnet: None, spacing: None, designrulewidth: None, mask: Some(m), rects: rl, polygons: None },
  "-" "LAYER" <l:identifier> "FILLS" <rl:rect_list> semicolon
    => BlockageRouting { layer: l, component: None, slots: None, fills: Some(true), pushdown: None, exceptpgnet: None, spacing: None, designrulewidth: None, mask: None, rects: rl, polygons: None },
  "-" "LAYER" <l:identifier> <rl:rect_list> semicolon
    => BlockageRouting { layer: l, component: None, slots: None, fills: None, pushdown: None, exceptpgnet: None, spacing: None, designrulewidth: None, mask: None, rects: rl, polygons: None },
}

blockage: Blockage = {
  <bp:blockage_placement> => Blockage::Placement(bp),
  <br:blockage_routing> => Blockage::Routing(br),
}

blockages: Vec<Blockage> = {
  "BLOCKAGES" <n:integer> semicolon <bl:blockage*> "END" "BLOCKAGES" => bl,
}

