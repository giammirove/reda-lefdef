////////////////////////////////////////////////////////////////////////////////

net_source: NetSource = {
  "NETLIST" => NetSource::NETLIST,
  "DIST" => NetSource::DIST,
  "USER" => NetSource::USER,
  "TIMING" => NetSource::TIMING,
  "TEST" => NetSource::TEST,
}

net_use: NetUse = {
  "ANALOG" => NetUse::ANALOG,
  "CLOCK" => NetUse::CLOCK,
  "GROUND" => NetUse::GROUND,
  "POWER" => NetUse::POWER,
  "RESET" => NetUse::RESET,
  "SCAN" => NetUse::SCAN,
  "SIGNAL" => NetUse::SIGNAL,
  "TIEOFF" => NetUse::TIEOFF,
}

net_opts: NetOpts = {
  "+" "SOURCE" <s:net_source> <mut o:net_opts> => set_opt!(o,source,s),
  "+" "FIXEDBUMP" <mut o:net_opts> => set_opt!(o,fixedbump,true),
  "+" "FREQUENCY" <f:real> <mut o:net_opts> => set_opt!(o,frequency,f),
  "+" "ORIGINAL" <or:identifier> <mut o:net_opts> => set_opt!(o,original,or),
  "+" "USE" <u:net_use> <mut o:net_opts> => set_opt!(o,use_type,u),
  "+" "PATTERN" <p:identifier> <mut o:net_opts> => set_opt!(o,pattern,p),
  "+" "ESTCAP" <e:real> <mut o:net_opts> => set_opt!(o,estcap,e),
  "+" "WEIGHT" <w:integer> <mut o:net_opts> => set_opt!(o,weight,w),
  "+" "XTALK" <x:integer> <mut o:net_opts> => set_opt!(o,xtalk,x),
  "+" "NONDEFAULTRULE" <n:identifier> <mut o:net_opts>
    => set_opt!(o,nondefaultrule,n),
  "+" "PROPERTY" <pl:property+> <mut o:net_opts>
    => set_opt!(o,properties,pl),
  () => NetOpts::default(),
}

net: Net = {
  "-" <name:identifier> <cl:connection_list> <opts:net_opts> semicolon
    => Net { name, opts: NetOpts { connections: Some(cl), ..opts } },
}

nets: Vec<Net> = {
  "NETS" <n:integer> semicolon <nl:net*> "END" "NETS" => nl,
}

