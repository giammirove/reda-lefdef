ndr_layer: NonDefaultRuleLayer = {
  "+" "LAYER" <name:identifier> "WIDTH" <w:integer>
    <dw:diagwidth?> <s:spacing?> <we:wireext?> 
    => NonDefaultRuleLayer { name, width: w, diagwidth: dw, spacing: s, wireext: we },
}

ndr_via: String = {
  "+" "VIA" <v:identifier> => v,
}

ndr_viarule: String = {
  "+" "VIARULE" <v:identifier> => v,
}

ndr_mincut: (String, i32) = {
  "+" "MINCUTS" <layer:identifier> <num:integer> => (layer, num),
}

ndr_prop: Vec<Property> = {
  "+" "PROPERTY" <pl:property+> => pl,
}

hardspacing: bool = {
  "+" "HARDSPACING" => true,
}

nondefaultrule: NonDefaultRule = {
  "-" <name:identifier> <hs:hardspacing?> <ll:ndr_layer+>
    <vl:ndr_via+?> <vrl:ndr_viarule+?> <ml:ndr_mincut+?>
    <props:ndr_prop?> semicolon
    => NonDefaultRule {
      name,
      hardspacing: hs,
      layers: ll,
      vias: vl,
      viarules: vrl,
      mincuts: ml,
      properties: props,
    },
}

nondefaultrules: Vec<NonDefaultRule> = {
  "NONDEFAULTRULES" <n:integer> semicolon <nl:nondefaultrule*> "END" "NONDEFAULTRULES" => nl,
}

