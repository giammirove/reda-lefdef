group_region: String = {
 "+" "REGION" <r:identifier> => r,
}

group_property: Property = {
  "+" "PROPERTY" <pl:property> => pl,
}

group: Group = {
  "-" <name:identifier> <cl:comp_name+> <r:group_region?>
     <pl:group_property+?> semicolon
    => Group { name, components: cl, region: r, properties: pl },
