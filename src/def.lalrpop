//                                                                            //
//  Special Wiring for SPECIALNETS                                            //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

special_wire_type: SpecialWireType = {
  "COVER" => SpecialWireType::COVER,
  "FIXED" => SpecialWireType::FIXED,
  "ROUTED" => SpecialWireType::ROUTED,
  "SHIELD" <n:identifier> => SpecialWireType::SHIELD(n),
}

special_wire_shape: SpecialWireShape = {
  "RING" => SpecialWireShape::RING,
  "PADRING" => SpecialWireShape::PADRING,
  "BLOCKRING" => SpecialWireShape::BLOCKRING,
  "STRIPE" => SpecialWireShape::STRIPE,
  "FOLLOWPIN" => SpecialWireShape::FOLLOWPIN,
  "IOWIRE" => SpecialWireShape::IOWIRE,
  "COREWIRE" => SpecialWireShape::COREWIRE,
  "BLOCKWIRE" => SpecialWireShape::BLOCKWIRE,
  "BLOCKAGEWIRE" => SpecialWireShape::BLOCKAGEWIRE,
  "FILLWIRE" => SpecialWireShape::FILLWIRE,
  "FILLWIREOPC" => SpecialWireShape::FILLWIREOPC,
  "DRCFILL" => SpecialWireShape::DRCFILL,
}

special_net_source: SpecialNetSource = {
  "DIST" => SpecialNetSource::DIST,
  "NETLIST" => SpecialNetSource::NETLIST,
  "TIMING" => SpecialNetSource::TIMING,
  "USER" => SpecialNetSource::USER,
}

special_net_use: SpecialNetUse = {
  "ANALOG" => SpecialNetUse::ANALOG,
  "CLOCK" => SpecialNetUse::CLOCK,
  "GROUND" => SpecialNetUse::GROUND,
  "POWER" => SpecialNetUse::POWER,
  "RESET" => SpecialNetUse::RESET,
  "SCAN" => SpecialNetUse::SCAN,
  "SIGNAL" => SpecialNetUse::SIGNAL,
  "TIEOFF" => SpecialNetUse::TIEOFF,
}

special_net_pattern: SpecialNetPattern = {
  "BALANCED" => SpecialNetPattern::BALANCED,
  "STEINER" => SpecialNetPattern::STEINER,
  "TRUNK" => SpecialNetPattern::TRUNK,
  "WIREDLOGIC" => SpecialNetPattern::WIREDLOGIC,
}

// Geometry-based wiring (first syntax pattern)
special_wire_polygon_geom: SpecialWireSegment = {
  "+" "SHAPE" <s:special_wire_shape> "+" "MASK" <m:integer> "+" "POLYGON" <layer:identifier> <pts:point_list>
    => SpecialWireSegment::Polygon(SpecialWirePolygonGeom { 
      layer, points: pts, shape: Some(s), mask: Some(m) 
    }),
}

special_wire_rect_geom: SpecialWireSegment = {
  "+" "SHAPE" <s:special_wire_shape> "+" "MASK" <m:integer> "+" "RECT" <layer:identifier> <pt1:point> <pt2:point>
    => SpecialWireSegment::Rect(SpecialWireRectGeom { 
      layer, pt1, pt2, shape: Some(s), mask: Some(m)
    }),
  "+" "SHAPE" <s:special_wire_shape> "+" "RECT" <layer:identifier> <pt1:point> <pt2:point>
    => SpecialWireSegment::Rect(SpecialWireRectGeom { 
      layer, pt1, pt2, shape: Some(s), mask: None 
    }),
  "+" "MASK" <m:integer> "+" "RECT" <layer:identifier> <pt1:point> <pt2:point>
    => SpecialWireSegment::Rect(SpecialWireRectGeom { 
      layer, pt1, pt2, shape: None, mask: Some(m) 
    }),
  "+" "RECT" <layer:identifier> <pt1:point> <pt2:point>
    => SpecialWireSegment::Rect(SpecialWireRectGeom { 
      layer, pt1, pt2, shape: None, mask: None 
    }),
}

special_wire_via_geom: SpecialWireSegment = {
  "+" "SHAPE" <s:special_wire_shape> "+" "MASK" <m:integer> "+" "VIA" <via:identifier> <o:orient?> <pts:point_list>
    => SpecialWireSegment::Via(SpecialWireViaGeom { 
      via, orient: o, points: pts, shape: Some(s), mask: Some(m) 
    }),
  "+" "SHAPE" <s:special_wire_shape> "+" "VIA" <via:identifier> <o:orient?> <pts:point_list>
    => SpecialWireSegment::Via(SpecialWireViaGeom { 
      via, orient: o, points: pts, shape: Some(s), mask: None 
    }),
  "+" "MASK" <m:integer> "+" "VIA" <via:identifier> <o:orient?> <pts:point_list>
    => SpecialWireSegment::Via(SpecialWireViaGeom { 
      via, orient: o, points: pts, shape: None, mask: Some(m) 
    }),
  "+" "VIA" <via:identifier> <o:orient?> <pts:point_list>
    => SpecialWireSegment::Via(SpecialWireViaGeom { 
      via, orient: o, points: pts, shape: None, mask: None 
    }),
}

special_wire_path_segment: SpecialWireSegment = {
  <layer:identifier> <width:integer> 
    "+" "SHAPE" <s:special_wire_shape> "+" "STYLE" <st:integer> <pts:routing_points>
    => SpecialWireSegment::Path(SpecialWirePathSegment { 
      layer, width, shape: Some(s), style: Some(st), points: pts 
    }),
  <layer:identifier> <width:integer> 
    "+" "SHAPE" <s:special_wire_shape> <pts:routing_points>
    => SpecialWireSegment::Path(SpecialWirePathSegment { 
      layer, width, shape: Some(s), style: None, points: pts 
    }),
  <layer:identifier> <width:integer> 
    "+" "STYLE" <st:integer> <pts:routing_points>
    => SpecialWireSegment::Path(SpecialWirePathSegment { 
      layer, width, shape: None, style: Some(st), points: pts 
    }),
  <layer:identifier> <width:integer> <pts:routing_points>
    => SpecialWireSegment::Path(SpecialWirePathSegment { 
      layer, width, shape: None, style: None, points: pts 
    }),
}

special_wire_segment: SpecialWireSegment = {
  special_wire_polygon_geom,
  special_wire_rect_geom,
  special_wire_via_geom,
  special_wire_path_segment,
}

special_wire_segments: Vec<SpecialWireSegment> = {
  <s:special_wire_segment> "NEW" <mut l:special_wire_segments> => { l.push(s); l },
  <s:special_wire_segment> => vec![s],
}

special_wiring: SpecialWiring = {
  "+" <wt:special_wire_type> <segs:special_wire_segments>
    => SpecialWiring { wire_type: wt, segments: segs },
}

special_net_opts: SpecialNetOpts = {
  "+" "VOLTAGE" <v:real> <mut o:special_net_opts> => set_opt!(o,voltage,v),
  <wl:special_wiring> <mut o:special_net_opts> => vec_push![o, wires, wl],
  "+" "SOURCE" <s:special_net_source> <mut o:special_net_opts> => set_opt!(o,source,s),
  "+" "FIXEDBUMP" <mut o:special_net_opts> => set_opt!(o,fixedbump,true),
  "+" "ORIGINAL" <or:identifier> <mut o:special_net_opts>
    => set_opt!(o,original,or),
  "+" "USE" <u:special_net_use> <mut o:special_net_opts> => set_opt!(o,use_type,u),
  "+" "PATTERN" <p:special_net_pattern> <mut o:special_net_opts> => set_opt!(o,pattern,p),
  "+" "ESTCAP" <e:real> <mut o:special_net_opts> => set_opt!(o,estcap,e),
  "+" "WEIGHT" <w:integer> <mut o:special_net_opts> => set_opt!(o,weight,w),
  "+" "PROPERTY" <pl:property+> <mut o:special_net_opts>
    => set_opt!(o,properties,pl),
  () => SpecialNetOpts::default(),
  ! => panic_with_context!("error parsing special net", <>),
}

connection: (String, String) = {
  "(" <c:pattern_match> <p:pin_name> ")" => (c, p),
  "(" <c:identifier> <p:pin_name> ")" => (c, p),
}

connection_list: Vec<(String, String)> = {
  <c:connection+> => c,
}

special_net: SpecialNet = {
  "-" <name:identifier> <cl:connection_list?> <opts:special_net_opts> semicolon
    => SpecialNet { name, opts: SpecialNetOpts { connections: cl, ..opts } },
}

specialnets: Vec<SpecialNet> = {
  "SPECIALNETS" <n:integer> semicolon <snl:special_net*> "END" "SPECIALNETS"
    => snl,
}

