//                                                                            //
//  FILLS Section                                                             //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

fill_rect: FillRect = {
  "-" "LAYER" <l:identifier> "MASK" <m:integer> "OPC" <rl:rect_list> semicolon
    => FillRect { layer: l, mask: Some(m), opc: Some(true), rects: rl },
  "-" "LAYER" <l:identifier> <rl:rect_list> semicolon
    => FillRect { layer: l, mask: None, opc: None, rects: rl },
}

fill_via: FillVia = {
  "-" "VIA" "MASK" <m:integer> "OPC" <v:identifier> <pl:point_list> semicolon
    => FillVia { mask: Some(m), opc: Some(true), via: v, points: pl },
  "-" "VIA" <v:identifier> <pl:point_list> semicolon
    => FillVia { mask: None, opc: None, via: v, points: pl },
}

fill: Fill = {
  <fr:fill_rect> => Fill::Rect(fr),
  <fv:fill_via> => Fill::Via(fv),
}

fill_list: Vec<Fill> = {
  <f:fill> <mut l:fill_list> => { l.push(f); l },
  <f:fill> => vec![f],
}

fills: Vec<Fill> = {
  "FILLS" <n:integer> semicolon <fl:fill_list> "END" "FILLS" => fl,
}

