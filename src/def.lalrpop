}

////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  Main Body                                                                 //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

body: DEF = {
  <v:version> <mut d:body> => set_opt!(d,version,v),
  <dc:dividerchar> <mut d:body> => set_opt!(d,dividerchar,dc),
  <bbc:busbitchars> <mut d:body> => set_opt!(d,busbitchars,bbc),
  <n:design_name> <mut d:body> => set_opt!(d,design_name,n),
  <t:technology> <mut d:body> => set_opt!(d,technology,t),
  <u:units> <mut d:body> => set_opt!(d,units,u),
  <h:history> <mut d:body> => vec_push!(d,history,h),
  <pd:propertydefinitions> <mut d:body> => set_opt!(d,propertydefinitions,pd),
  <da:diearea> <mut d:body> => set_opt!(d,diearea,da),
  <r:row> <mut d:body> => vec_push![d, rows, r],
  <t:tracks> <mut d:body> => vec_push![d, tracks, t],
  <g:gcellgrid> <mut d:body> => vec_push![d, gcellgrids, g],
  <v:vias> <mut d:body> => set_opt!(d,vias,v),
  <s:styles> <mut d:body> => set_opt!(d,styles,s),
  <ndr:nondefaultrules> <mut d:body> => set_opt!(d,nondefaultrules,ndr),
  <reg:regions> <mut d:body> => set_opt!(d,regions,reg),
  <cms:componentmaskshift> <mut d:body> => set_opt!(d,componentmaskshift,cms),
  <c:components> <mut d:body> => set_opt!(d,components,c),
  <p:pins> <mut d:body> => set_opt!(d,pins,p),
  <pp:pinproperties> <mut d:body> => set_opt!(d,pinproperties,pp),
  <b:blockages> <mut d:body> => set_opt!(d,blockages,b),
  <sl:slots> <mut d:body> => set_opt!(d,slots,sl),
  <fl:fills> <mut d:body> => set_opt!(d,fills,fl),
  <sn:specialnets> <mut d:body> => set_opt!(d,specialnets,sn),
  <n:nets> <mut d:body> => set_opt!(d,nets,n),
  <sc:scanchains> <mut d:body> => set_opt!(d,scanchains,sc),
  <g:groups> <mut d:body> => set_opt!(d,groups,g),
  <s:site> <mut d:body> => vec_push![d, sites, s],
  <el:extension> <mut d:body> => vec_push![d, extensions, el],
  () => DEF::default(),
  ! => panic!("[x] error parsing DEF body: {:?} {:?}", <>.error, <>.dropped_tokens.into_iter().take(10).collect::<Vec<_>>()),
};

pub def: DEF = {
  comment <d:def> => d,
  <b:body> "END" "DESIGN" => b,
};
