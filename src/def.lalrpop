//  SLOTS Section                                                             //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

slot: Slot = {
  "-" "LAYER" <l:identifier> <rl:rect_list> semicolon
    => Slot { layer: l, rects: rl, polygons: None },
}

slot_list: Vec<Slot> = {
  <s:slot> <mut l:slot_list> => { l.push(s); l },
  <s:slot> => vec![s],
}

slots: Vec<Slot> = {
  "SLOTS" <n:integer> semicolon <sl:slot_list> "END" "SLOTS" => sl,
}

