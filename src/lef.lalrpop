////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  NONDEFAULTRULE                                                            //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

// [NONDEFAULTRULE ruleName
//     [HARDSPACING ;]
//     {LAYER layerName
//        WIDTH width ;
//        [DIAGWIDTH diagWidth ;]
//        [SPACING minSpacing ;] 
//        [WIREEXTENSION value ;]
//     END layerName} ...
//     [VIA viaStatement] ...
//     [USEVIA viaName ;] ...
//     [USEVIARULE viaRuleName ;] ...
//     [MINCUTS cutLayerName numCuts ;] ...
//     [PROPERTY propName propValue ;] ... 
// 
// END ruleName]

nondefaultrule_layer_opts: NonDefaultRuleLayerOpts = {
  "DIAGWIDTH" <v:real> semicolon <mut o:nondefaultrule_layer_opts> => set_opt![o,diagwidth,v],
  "SPACING" <v:real> semicolon <mut o:nondefaultrule_layer_opts> => set_opt![o,spacing,v],
  "WIREEXTENSION" <v:real> semicolon <mut o:nondefaultrule_layer_opts> => set_opt![o,wireextension,v],
  () => <NonDefaultRuleLayerOpts as std::default::Default>::default()
}

nondefaultrule_layer: NonDefaultRuleLayer = {
  "LAYER" <n:identifier> comment_opt
  "WIDTH" <w:real> semicolon
  <o:nondefaultrule_layer_opts>
  //<o:layer_opts>
  <chk_n:end_name>
    => NonDefaultRuleLayer::new(n,w,o,chk_n),
}

nondefaultrule_opts: NonDefaultRuleOpts = {
  "HARDSPACING" semicolon <mut o:nondefaultrule_opts> => set_opt![o,hardspacing,true],
  <v:nondefaultrule_layer> <mut o:nondefaultrule_opts> => vec_push![o,layers,v],
  <v:via> <mut o:nondefaultrule_opts> => vec_push![o,vias,v],
  "USEVIA" <n:identifier> semicolon <mut o:nondefaultrule_opts> => vec_push![o,usevias,n],
  "USEVIARULE" <n:identifier> semicolon <mut o:nondefaultrule_opts> => vec_push![o,useviarules,n],
  <v:mincuts> <mut o:nondefaultrule_opts> => vec_push![o,mincuts,v],
  <v:property> <mut o:nondefaultrule_opts> => vec_push![o,properties,v],
  () => <NonDefaultRuleOpts as std::default::Default>::default()
}

nondefaultrule: NonDefaultRule= {
  "NONDEFAULTRULE" <n:identifier> comment_opt
    <o:nondefaultrule_opts>
  <chk_n:end_name>
    => NonDefaultRule::new(n,o,chk_n),
}


