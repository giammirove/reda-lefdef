// { LAYER layerName
//         [EXCEPTPGNET]
//         [SPACING minSpacing | DESIGNRULEWIDTH value] ;
//       [WIDTH width ;]
//       { PATH [MASK maskNum] pt ... ; 
//       | PATH [MASK maskNum] ITERATE pt ... stepPattern ;
//       | RECT [MASK maskNum] pt pt ; 
//       | RECT [MASK maskNum] ITERATE pt pt stepPattern ;
//       | POLYGON [MASK maskNum] pt pt pt pt ... ;
//       | POLYGON [MASK maskNum] ITERATE pt pt pt pt ... stepPattern ;
//       } ...
//     | VIA [MASK viaMaskNum] pt viaName ;
//     | VIA ITERATE [MASK viaMaskNum] pt viaName stepPattern ;
//     } ...
spacing_designrulewidth: LayerGeomDesign = {
  <s:simple_spacing_no_semicolon> => LayerGeomDesign::SPACING(s),
  <d:designrulewidth_no_semicolon> => LayerGeomDesign::DESIGNRULEWIDTH(d),
}

layer_geom_shape: LayerGeomShape = {
  "PATH" <m:mask_no_semicolon?> <p:point*> semicolon
    => LayerGeomShape::PATH(LayerGeomShapePath::new(m,p,None)),
  "PATH" <m:mask_no_semicolon?> "ITERATE" <p:point*> <s:step_pattern?> semicolon
    => LayerGeomShape::PATH(LayerGeomShapePath::new(m,p,s)),

  "RECT" <m:mask_no_semicolon?> <p1:point> <p2:point> semicolon
    => LayerGeomShape::RECT(LayerGeomShapeRect::new(m,Rect::new(p1,p2),None)),
  "RECT" <m:mask_no_semicolon?> "ITERATE" <p1:point> <p2:point> <s:step_pattern?> semicolon
    => LayerGeomShape::RECT(LayerGeomShapeRect::new(m,Rect::new(p1,p2),s)),

  "POLYGON" <m:mask_no_semicolon?> <p:point*> semicolon
    => LayerGeomShape::POLYGON(LayerGeomShapePolygon::new(m,Polygon::new(p),None)),
  "POLYGON" <m:mask_no_semicolon?> "ITERATE" <p:point*> <s:step_pattern?> semicolon
    => LayerGeomShape::POLYGON(LayerGeomShapePolygon::new(m,Polygon::new(p),s)),
}

layer_geom_layer: LayerGeomLayer = {
  "LAYER" <n:identifier> <e:exceptpgnet> <sd:spacing_designrulewidth?> semicolon
    <w:layer_width?>
    <shapes:layer_geom_shape*>
      => LayerGeomLayer::new(n,e,sd,w,shapes),
}
layer_geom_via: LayerGeomVia = {
  "VIA" <m:mask_no_semicolon?> <p:point> <n:identifier> semicolon
    => LayerGeomVia::new(m,p,n,None),
  "VIA ITERATE" <m:mask_no_semicolon?> <p:point> <n:identifier> <s:step_pattern?> semicolon
    => LayerGeomVia::new(m,p,n,s),
}
layer_geom: LayerGeom = {
  <l:layer_geom_layer> => LayerGeom::LAYER(l),
  <v:layer_geom_via> => LayerGeom::VIA(v),
}
macro_pin_port: MacroPinPort = {
  "PORT" comment_opt 
    <c:macro_pin_port_class?> 
    <g:layer_geom*>
  end
    => MacroPinPort::new(c,g),
}

macro_pin_opts: MacroPinOpts = {
  <v:macro_pin_taperrule> <mut o:macro_pin_opts> => { o.taperrule = Some(v); o },
  <v:macro_pin_direction> <mut o:macro_pin_opts> => { o.direction = Some(v); o },
  <v:macro_pin_use> <mut o:macro_pin_opts> => { o.puse = Some(v); o },
  <v:macro_pin_netexpr> <mut o:macro_pin_opts> => { o.netexpr = Some(v); o },
  <v:macro_pin_supplysensitivity> <mut o:macro_pin_opts> => { o.supplysensitivity = Some(v); o },
  <v:macro_pin_groundsensitivity> <mut o:macro_pin_opts> => { o.groundsensitivity = Some(v); o },
  <v:macro_pin_shape> <mut o:macro_pin_opts> => { o.shape = Some(v); o },
  <v:macro_pin_mustjoin> <mut o:macro_pin_opts> => { o.mustjoin = Some(v); o },
  <v:antennapartialmetalarea> <mut o:macro_pin_opts> => { o.antennapartialmetalarea = Some(v); o },
  <v:antennapartialmetalsidearea> <mut o:macro_pin_opts> => { o.antennapartialmetalsidearea = Some(v); o },
  <v:antennapartialcutarea> <mut o:macro_pin_opts> => { o.antennapartialcutarea= Some(v); o },
  <v:antennadiffarea> <mut o:macro_pin_opts> => { o.antennadiffarea= Some(v); o },
  <v:antennamodel> <mut o:macro_pin_opts> => { o.antennamodel = Some(v); o },
  <v:antennagatearea> <mut o:macro_pin_opts> => { o.antennagatearea = Some(v); o },
  <v:antennamaxareacar> <mut o:macro_pin_opts> => { o.antennamaxareacar = Some(v); o },
  <v:antennamaxsideareacar> <mut o:macro_pin_opts> => { o.antennamaxsideareacar = Some(v); o },
  <v:antennamaxcutcar> <mut o:macro_pin_opts> => { o.antennamaxcutcar = Some(v); o },
  <v:macro_pin_port> <mut o:macro_pin_opts> => vec_push![o,ports,v],
  <v:property> <mut o:macro_pin_opts> => vec_push![o,properties,v],
  () => <MacroPinOpts as std::default::Default>::default()
}
macro_pin: MacroPin = {
  "PIN" <n:identifier>
    <o:macro_pin_opts>
    "END" <chk_n:identifier>
    => MacroPin::new(n,o,chk_n),
}

macro_obs: MacroObstruction = {
  "OBS"
    <g:layer_geom*>
    "END" => MacroObstruction::new(g),
}

// [DENSITY
//    {LAYER layerName ;
//       {RECT x1 y1 x2 y2 densityValue ;} ...
//    } ...
// END] ...

macro_density_layer_rect: MacroDensityLayerRect = {
  "RECT" <x1:real> <y1:real> <x2:real> <y2:real> <d:real> semicolon
    => MacroDensityLayerRect::new(Point::new(x1,y1,None), Point::new(x2,y2,None), d),
};

macro_density_layer: MacroDensityLayer = {
  "LAYER" <n:identifier> semicolon
    <l:macro_density_layer_rect*> 
    => MacroDensityLayer::new(n,l),
}

macro_density: MacroDensity = {
  "DENSITY"
    <l:macro_density_layer*>
  "END"
    => MacroDensity::new(l),
}

//    [FOREIGN foreignCellName [pt [orient]] ;] ... 
//    [ORIGIN pt ;]
//    [EEQ macroName ;]
//    [SIZE width BY height ;]
//    [SYMMETRY {X | Y | R90} ... ;]
//    [SITE siteName [sitePattern] ;] ...
//    [PIN statement] ...
//    [OBS statement] ...
//    [DENSITY statement] ...
//    [PROPERTY propName propVal ;] ...
macro_opts: MacroOpts = {
  <v:macro_class> <mut o:macro_opts> => { o.class = Some(v); o },
  <v:foreign> <mut o:macro_opts> => vec_push![o,foreigns,v],
  <v:origin> <mut o:macro_opts> => { o.origin = Some(v); o },
  <v:macro_eeq> <mut o:macro_opts> => { o.eeq = Some(v); o },
  <v:size> <mut o:macro_opts> => { o.size = Some(v); o },
  <v:symmetry> <mut o:macro_opts> => { o.symmetries = Some(v); o },
  <v:macro_site> <mut o:macro_opts> => vec_push![o,sites,v],
  <v:macro_pin> <mut o:macro_opts> => vec_push![o,pins,v],
  <v:macro_obs> <mut o:macro_opts> => vec_push![o,obstructions,v],
  <v:macro_density> <mut o:macro_opts> => vec_push![o,densities,v],
  <v:fixedmask> <mut o:macro_opts> => { o.fixedmask = Some(true); o },
  <v:property> <mut o:macro_opts> => vec_push![o,properties,v],
  () => <MacroOpts as std::default::Default>::default()
}

macro: Macro = {
  "MACRO" <n:identifier>
    <o:macro_opts>
    "END" <chk_n:identifier>
      => Macro::new(n,o,chk_n),
}


////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  SPACINGS section
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

spacing: Spacing = {
    <sm:samenet?>
    <l1:identifier> <l2:identifier> <s:real> <st:stack?> semicolon
    => Spacing::new(sm, l1, l2, s, st)
}
spacings: Vec<Spacing> = {
  "SPACING"
  <ss:spacing*>
  "END" "SPACING"
    => ss,
};

////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  End MACRO                                                                 //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

body: LEF = {
  // Header 
  <v:version> <mut b:body> => { b.version = v; b },
  <v:namescasesensitive> <mut b:body> => set_opt![b,namescasesensitive,v],
  <v:nowireextensionatpin> <mut b:body> => set_opt![b,nowireextensionatpin,v],
  <v:busbitchars> <mut b:body> => { b.busbitchars = Some(v); b },
  <v:dividerchar> <mut b:body> => { b.dividerchar = Some(v); b },
  <v:units> <mut b:body> => set_opt![b,units,v],
  <v:manufacturinggrid> <mut b:body> => set_opt![b,manufacturinggrid,v],
  <v:useminspacingobs> <mut b:body> => set_opt![b,useminspacingobs,v],
  <v:useminspacingpin> <mut b:body> => set_opt![b,useminspacingpin,v],
  <v:clearancemeasure> <mut b:body> => set_opt![b,clearancemeasure,v],
  fixedmask <mut b:body> => set_opt![b,fixedmask,true],
  <v:maxviastack> <mut b:body> => set_opt![b,maxviastack,v],
  // End Header

  <v:propertydefinitions> <mut b:body> => set_opt![b,propertydefinitions,v],
  <v:spacings> <mut b:body> => set_opt![b,spacings,v],
  <v:layer> <mut c:body> => vec_push![c,layers,v],
  <v:via> <mut c:body> => vec_push![c,vias,v],
  <v:viarule> <mut c:body> => vec_push![c,viarules,v],
  <v:viarulegenerate> <mut c:body> => vec_push![c,viarules,v],
  <v:nondefaultrule> <mut c:body> => vec_push![c,nondefaultrules,v],
  <v:site> <mut c:body> => vec_push![c,sites,v],
  <v:macro> <mut c:body> => vec_push![c,macros,v],
  () => <LEF as std::default::Default>::default(),
  ! => panic_with_context!("error parsing body", <>),
};

pub lef: LEF = {
  comment <b:lef> => b,
  <b:body> "END LIBRARY" comment_opt => b,
};
