  // "SAMENET" => <>.to_string(),
}

non_keyword_identifier: String = {
    // compile time really slow with size bound ... :(
    // r#"[^"^\s^\t^\n][^\s^\t^\n]{0,2048}"# => <>.to_string(),
    // possible bug in LALRPOP .. or maybe not .. something to do with the lexer
    r#"[^"^\s^\t^\n^#^(^\-^\.^\d^\*][^\s^\t^\n^#^\*]*"# => <>.to_string(),
}

// We explicitly list all keywords here as valid identifiers to avoid having
// to use weird hacks elsewhere in the grammar to disambiguate between real
// tokens and identifiers. LALRPOP string literals have global lexer priority
// over regex rules, so any keyword used elsewhere in the grammar would never
// match the identifier regex. The tradeoff is that every new keyword added
// to the grammar must also be added here if it can appear in an identifier
// position.
identifier: String = {
    <ident:non_keyword_identifier> => ident,
    <k:keyword> => k, 
};

real: f32 = {
  r#"(-)?[\d]+[\.\deE]*"# => f32::from_str(&<>).unwrap_or_else(|_| panic!("'{}' is not an float", &<>)),
};

integer: i32 = {
  <n:real> => n.round() as i32,
};

string: String = {
  <r#"\"[\w\d\n\s\-\[\];'\\,\./~!@#$%^&\*\(\)_\+{}:|<>\?]*\""#> => <>.to_string(),
};

real_pair: (f32, f32) = {
  "(" <n1:real> <n2:real> ")" => (n1,n2)
};

real_pair_list_: Vec<(f32, f32)> = {
  <mut l:real_pair_list_> <p:real_pair>  
    => { l.push(p); l },
  <p:real_pair> => vec![p]
};

real_pair_list: Vec<(f32, f32)> = {
  "(" <real_pair_list_> ")" => <>
}

real_list: Vec<f32> = {
  <n:real> <mut l:real_list> 
    => { l.push(n); l },
  <n:real> => vec![n]
};

semicolon: () = {
  ";" comment_opt
};

newline: () = {
  "\n",
}

end: () = {
  "END" comment_opt,
  "END" newline,
}
end_name: String = {
  "END" <n:identifier> comment_opt => <>,
  "END" <n:identifier> newline => <>,
}

comment: () = {
  r"#.*\n",
};
comment_opt: () = {
  comment comment_opt,
  comment newline comment_opt,
  ()
};

width: f32 = {
  "WIDTH" <n:real> => n
};

value: Value = {
  real => Value::NUMBER(<>),
  string => Value::STRING(<>),
};

mask: i32 = {
  "MASK" <n:integer> semicolon => n
};

mask_no_semicolon: i32 = {
  "MASK" <n:integer> => n
};

property_name_value: NameValue = {
  <i:identifier> <v:value> => NameValue::new(i,v),
};

property: Property = {
  "PROPERTY" <l:property_name_value*> semicolon
    => Property::new(l),
};

resistance: f32 = {
  "RESISTANCE" <n:real> semicolon => n
};

pwl: PieceWiseLinear = {
  real => PieceWiseLinear::REAL(<>),
  "PWL" <l:real_pair_list> => PieceWiseLinear::PWL(l),
};

range_no_semicolon: Range<f32> = {
  "RANGE" <min:real> <max:real> => (min,max),
}

tristate: bool = {
  "TRISTATE" => true,
};
exceptpgnet : bool = {
  "EXCEPTPGNET" => true,
  () => false,
};
simple_spacing_no_semicolon: f32 = {
