  "abutment" => MacroPinShape::ABUTMENT,
  "RING" => MacroPinShape::RING,
  "ring" => MacroPinShape::RING,
  "FEEDTHRU" => MacroPinShape::FEEDTHRU,
  "feedthru" => MacroPinShape::FEEDTHRU,
}
