layer_cut_opts: LayerCutOpts = {
  <v:mask> <mut c:layer_cut_opts> => { c.mask = Some(v); c },

  <v:layer_cut_spacing> <mut c:layer_cut_opts> => vec_push![c,spacings,v],
  <v:layer_cut_spacingtable> <mut c:layer_cut_opts> => set_opt![c,spacingtable,v],

  <v:layer_arrayspacing> <mut c:layer_cut_opts> =>  { c.arrayspacing = Some(v) ; c },
  <v:layer_width> <mut c:layer_cut_opts> =>  { c.width = Some(v) ; c },
  <v:layer_diagwidth> <mut c:layer_cut_opts> => { c.diagwidth = Some(v); c },
  <v:layer_diagspacing> <mut c:layer_cut_opts> => { c.diagspacing = Some(v); c },
  <v:layer_diagminedgelength> <mut c:layer_cut_opts> => { c.diagminedgelength = Some(v); c },
  <v:layer_offset> <mut c:layer_cut_opts> => { c.offset = Some(v); c },
  <v:layer_pitch> <mut c:layer_cut_opts> => { c.pitch = Some(v); c },
  <v:layer_diagpitch> <mut c:layer_cut_opts> => { c.diagpitch = Some(v); c },
  <v:layer_enclosure> <mut c:layer_cut_opts> =>  vec_push![c,enclosures,v],
  <v:layer_preferenclosure> <mut c:layer_cut_opts> => vec_push![c,preferenclosures,v],
  <v:layer_cut_resistance> <mut c:layer_cut_opts> =>  { c.resistance = Some(v) ; c },
  <v:layer_cut_capacitance> <mut c:layer_cut_opts> =>  { c.capacitance = Some(v) ; c },
  <v:layer_accurrentdensity> <mut c:layer_cut_opts> =>  { c.accurrentdensity = Some(v) ; c },
  <v:layer_dccurrentdensity> <mut c:layer_cut_opts> =>  { c.dccurrentdensity = Some(v) ; c },

  <v:antennamodel> <mut c:layer_cut_opts> => vec_push![c,antennamodels,v],
  <v:layer_antennaarearatio> <mut c:layer_cut_opts> => vec_push![c,antennaarearatios,v],
  <v:layer_antennasidearearatio> <mut c:layer_cut_opts> => vec_push![c,antennasidearearatios,v],
  <v:layer_antennacumsidearearatio> <mut c:layer_cut_opts> => vec_push![c,antennacumsidearearatios,v],
  <v:layer_antennadiffsidearearatio> <mut c:layer_cut_opts> => vec_push![c,antennadiffsidearearatios,v],
  <v:layer_antennacumdiffsidearearatio> <mut c:layer_cut_opts> => vec_push![c,antennacumdiffsidearearatios,v],
  <v:layer_antennadiffarearatio> <mut c:layer_cut_opts> => vec_push![c,antennadiffarearatios,v],
  <v:layer_antennacumarearatio> <mut c:layer_cut_opts> => vec_push![c,antennacumarearatios,v],
  <v:layer_antennacumdiffarearatio> <mut c:layer_cut_opts> => vec_push![c,antennacumdiffarearatios,v],
  <v:layer_antennaareafactor> <mut c:layer_cut_opts> => vec_push![c,antennaareafactors,v],
  <v:layer_antennasideareafactor> <mut c:layer_cut_opts> => vec_push![c,antennasideareafactors,v],

  <v:layer_antennacumroutingpluscut> <mut c:layer_cut_opts> =>  { c.antennacumroutingpluscut = Some(v) ; c },
  <v:layer_antennagateplusdiff> <mut c:layer_cut_opts> =>  { c.antennagateplusdiff = Some(v) ; c },
  <v:layer_antennaareaminusdiff> <mut c:layer_cut_opts> =>  { c.antennaareaminusdiff = Some(v) ; c },
  <v:layer_antennaareadiffreducepwl> <mut c:layer_cut_opts> =>  { c.antennaareadiffreducepwl = Some(v) ; c },
  <v:property> <mut c:layer_cut_opts> => vec_push![c,properties,v],
  () => <LayerCutOpts as std::default::Default>::default()
};
layer_cut: LayerCut = {
  "LAYER" <n:identifier> comment_opt
  "TYPE" "CUT" semicolon 
    <o:layer_cut_opts>
  <cn:end_name>
    => LayerCut::new(n,o,cn),
};

