  <x:real> <y:real> <o:orient?> 
    => Point::new(x,y,o),
}
point_orient: PointOrient = {
  <p:point_orient_no_semicolon> semicolon => p,
}
// TODO: point needs semicolon in some cases ???
point: Point = {
