propertydefinitions_values_object_type: PropertyDefinitionType = {
  "LAYER" =>  PropertyDefinitionType::LAYER,
  "LIBRARY" => PropertyDefinitionType::LIBRARY,
  "MACRO" => PropertyDefinitionType::MACRO,
  "NONDEFAULTRULE" => PropertyDefinitionType::NONDEFAULTRULE,
  "PIN" => PropertyDefinitionType::PIN,
  "VIA" => PropertyDefinitionType::VIA,
  "VIARULE" => PropertyDefinitionType::VIARULE,
};
propertydefinitions_values_prop_type: RangeOrValueEnum = {
  "INTEGER" <n:propertydefinitions_values_type_integer>
    => RangeOrValueEnum::Integer(Some(n)),
  "INTEGER" 
    => RangeOrValueEnum::Integer(None),
  "REAL" <n:propertydefinitions_values_type_real> 
    => RangeOrValueEnum::Real(Some(n)),
  "REAL" => RangeOrValueEnum::Real(None),
  "STRING" <s:string>
    => RangeOrValueEnum::String(Some(s.to_string())),
  "STRING" => RangeOrValueEnum::String(None)
};
propertydefinitions_values_type_real: RangeOrValue<f32> = {
  "RANGE" <n1:real> <n2:real> => Either::Left((n1,n2)),
  real => Either::Right(<>),
};
propertydefinitions_values_type_integer: RangeOrValue<i32> = {
  "RANGE" <n1:integer> <n2:integer> => Either::Left((n1,n2)),
  integer => Either::Right(<>),
};
propertydefinitions_values: PropertyDefinition = {
  <ot:propertydefinitions_values_object_type> <n:identifier>
    <pt:propertydefinitions_values_prop_type>
  semicolon
    => propertydefinition(ot, n, pt)
};
propertydefinitions: Vec<PropertyDefinition> = {
  "PROPERTYDEFINITIONS" 
    <l:propertydefinitions_values*>
  "END" "PROPERTYDEFINITIONS"
    => l 
};

