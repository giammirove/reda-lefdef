////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  VIA                                                                       //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

// VIA viaName [DEFAULT]
//    { VIARULE viaRuleName ;
//         CUTSIZE xSize ySize ;
//         LAYERS botMetalLayer cutLayer topMetalLayer ;
//         CUTSPACING xCutSpacing yCutSpacing ; 
//         ENCLOSURE xBotEnc yBotEnc xTopEnc yTopEnc ;
//         [ROWCOL numCutRows numCutCols ;] 
//         [ORIGIN xOffset yOffset ;] 
//         [OFFSET xBotOffset yBotOffset xTopOffset yTopOffset ;]
//         [PATTERN cutPattern ;]
//    }
//    | {[RESISTANCE resistValue ;]
//       {LAYER layerName ;
//         { RECT [MASK maskNum] pt pt ;
//         | POLYGON [MASK maskNum] pt pt pt ...;} ...
//       } ...
//      }
//    [PROPERTY propName propVal ;] ... 
// 
// END viaName

via_viarule_cutsize: Size = {
  "CUTSIZE" <x:real> <y:real> semicolon => Size::new(x,y),
}
via_viarule_layers: ViaViaRuleLayers = {
  "LAYERS" <b:identifier> <c:identifier> <t:identifier> semicolon => ViaViaRuleLayers::new(b,c,t),
}
via_viarule_cutspacing: Size = {
  "CUTSPACING" <x:real> <y:real> semicolon => Size::new(x,y),
}
via_viarule_enclosure: ViaViaRuleEnclosure = {
  "ENCLOSURE" <xb:real> <yb:real> <xt:real> <yt:real> semicolon => ViaViaRuleEnclosure::new(xb,yb,xt,yt),
}
via_viarule_rowcol: ViaViaRuleRowCol = {
  "ROWCOL" <r:integer> <c:integer> semicolon => ViaViaRuleRowCol::new(r,c),
}
via_viarule_origin: ViaViaRuleOrigin = {
  "ORIGIN" <x:real> <y:real> semicolon => ViaViaRuleOrigin::new(x,y),
}
via_viarule_offset: ViaViaRuleOffset = {
  "OFFSET" <xb:real> <yb:real> <xt:real> <yt:real> semicolon => ViaViaRuleOffset::new(xb,yb,xt,yt),
}
via_viarule_pattern: String = {
  "PATTERN" <cp:identifier> semicolon => cp,
}
via_viarule_opts: ViaViaRuleOpts = {
  <v:via_viarule_cutsize> <mut o:via_viarule_opts> => set_opt![o,cutsize,v],
  <v:via_viarule_layers>  <mut o:via_viarule_opts> => set_opt![o,layers,v],
  <v:via_viarule_cutspacing> <mut o:via_viarule_opts> => set_opt![o,cutspacing,v],
  <v:via_viarule_enclosure> <mut o:via_viarule_opts> => set_opt![o,enclosure,v],
  <v:via_viarule_rowcol> <mut o:via_viarule_opts> => set_opt![o,rowcol,v],
  <v:via_viarule_origin> <mut o:via_viarule_opts> => set_opt![o,origin,v],
  <v:via_viarule_offset>  <mut o:via_viarule_opts> => set_opt![o,offset,v],
  <v:via_viarule_pattern> <mut o:via_viarule_opts> => set_opt![o,pattern,v],
  () => <ViaViaRuleOpts as std::default::Default>::default(),
}
via_viarule: ViaViaRule = {
  "VIARULE" <n:identifier> semicolon
  <o:via_viarule_opts>
    => ViaViaRule::new(n,o),
}

via_shape: Shape = {
  "RECT" <m:mask_no_semicolon?> <x1:real> <y1:real> <x2:real> <y2:real> semicolon => Shape::new(m,ShapeEnum::RECT((x1,y1),(x2,y2))),
  "POLYGON" <m:mask_no_semicolon?> <l:real_list> semicolon => Shape::new(m,ShapeEnum::POLYGON(l)),
}
via_shapes: Vec<Shape> = {
  <v:via_shape> <mut l:via_shapes> => { l.push(v); l },
  via_shape => vec![<>],
}
via_layer: ViaLayer = {
  "LAYER" <id:identifier> semicolon <s:via_shapes> => ViaLayer::new(id,s),
}

via_layers: Vec<ViaLayer> = {
  <v:via_layer> <mut l:via_layers> => { l.push(v); l },
  via_layer => vec![<>],
}

via_props: (Option<Foreign>, Option<f32>) = {
  <r:resistance> <f:foreign> => (Some(f),Some(r)),
  <f:foreign> <r:resistance> => (Some(f),Some(r)),
  <r:resistance> => (None,Some(r)),
  <f:foreign> => (Some(f),None),
}

via_fixed: ViaFixed = {
  // trick to make it compile
  <rf:via_props> <l:via_layers> => ViaFixed::new(rf.0,rf.1,l),
  <l:via_layers> <rf:via_props> => ViaFixed::new(rf.0,rf.1,l),
  <l:via_layers> => ViaFixed::new(None,None,l),
}

via_type: ViaType = {
  <v:via_viarule> => ViaType::VIARULE(v),
  <vf:via_fixed> => ViaType::FIXED(vf),
}
via: Via = {
  "VIA" <n:identifier> <d:default> <g:generated> <t:topofstackonly> comment_opt
  <v:via_type> 
  <p:property*>
    <chk_n:end_name> 
    => Via::new(n,d,g,t,v,p,chk_n),
}


////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  End VIA                                                                   //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  VIARULE                                                                   //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

// VIARULE viaRuleName
//    LAYER layerName ;
//       DIRECTION {HORIZONTAL | VERTICAL} ;
//       [WIDTH minWidth TO maxWidth ;]
//    LAYER layerName ;
//       DIRECTION {HORIZONTAL | VERTICAL} ;
//       [WIDTH minWidth TO maxWidth ;]
//    {VIA viaName ;} ...
//    [PROPERTY propName propVal ;] ... 
//
// END viaRuleName

viarule_layer_direction_enum: ViaRuleLayerDirection = {
  "HORIZONTAL" => ViaRuleLayerDirection::HORIZONTAL,
  "VERTICAL" => ViaRuleLayerDirection::VERTICAL,
}
viarule_layer_width_range: Range<f32> = {
  "WIDTH" <min:real> "TO" <max:real> semicolon
    => (min,max),
}
viarule_layer_overhang: f32 = {
  "OVERHANG" <n:real> semicolon => n,
}
viarule_layer_metaloverhang: f32 = {
  "METALOVERHANG" <n:real> semicolon => n,
}
viarule_layer_direction: ViaRuleLayerDirection = {
  "DIRECTION" <d:viarule_layer_direction_enum> semicolon => d
}
viarule_layer_enclosure: (f32,f32) = {
  <enc:layer_enclosure> => enc.get_overhang(),
}
viarule_layer_opts: ViaRuleLayerOpts = {
  <v:viarule_layer_direction> <mut o:viarule_layer_opts> => set_opt![o,direction,v],
  <v:viarule_layer_enclosure> <mut o:viarule_layer_opts> => set_opt![o,enclosure,v],
  <v:viarule_layer_width_range> <mut o:viarule_layer_opts> => set_opt![o,widthrange,v],
  <v:viarule_layer_overhang> <mut o:viarule_layer_opts> => set_opt![o,overhang,v],
  <v:viarule_layer_metaloverhang> <mut o:viarule_layer_opts> => set_opt![o,metaloverhang,v],
  () => <ViaRuleLayerOpts as std::default::Default>::default()
}
viarule_layer: ViaRuleLayer = {
  "LAYER" <n:identifier> semicolon
     <o:viarule_layer_opts>
    => ViaRuleLayer::new(n,o),
}
viarule_via: String = {
  "VIA" <s:identifier> semicolon => s,
}

viarule_generate_cutlayer: ViaRuleGenerateCutLayer = {
  "LAYER" <n:identifier> semicolon
  "RECT" <p1:point> <p2:point> semicolon
  "SPACING" <xs:real> "BY" <ys:real> semicolon
  <ro:resistance?> 
    => ViaRuleGenerateCutLayer::new(n,Rect::new(p1,p2),(xs,ys),ro),
};

viarule: ViaRule = {
  "VIARULE" <n:identifier> <d:default> comment_opt
    <l1:viarule_layer>
    <l2:viarule_layer>
    <v:viarule_via*>
    <p:property*>
  <chk_n:end_name>
  => ViaRule::new(n,false,d,l1,l2,None,v,p,chk_n),
}

viarulegenerate: ViaRule = {
  "VIARULE" <n:identifier> "GENERATE" <d:default> comment_opt
    <l1:viarule_layer>
    <l2:viarule_layer>
    <l3:viarule_generate_cutlayer> 
    <p:property*>
  <chk_n:end_name>
  => ViaRule::new(n,true,d,l1,l2,Some(l3),vec![],p,chk_n),
  "VIARULE" <n:identifier> "GENERATE" <d:default> comment_opt
    <l1:viarule_layer>
    <l3:viarule_generate_cutlayer> 
    <l2:viarule_layer>
    <p:property*>
  <chk_n:end_name>
  => ViaRule::new(n,true,d,l1,l2,Some(l3),vec![],p,chk_n),
  "VIARULE" <n:identifier> "GENERATE" <d:default> comment_opt
    <l3:viarule_generate_cutlayer> 
    <l1:viarule_layer>
    <l2:viarule_layer>
    <p:property*>
  <chk_n:end_name>
  => ViaRule::new(n,true,d,l1,l2,Some(l3),vec![],p,chk_n),
  "VIARULE" <n:identifier> "GENERATE" <d:default> comment_opt
    <l1:viarule_layer>
    <l2:viarule_layer>
    <p:property*>
  <chk_n:end_name>
  => ViaRule::new(n,true,d,l1,l2,None,vec![],p,chk_n),
}

