   <x:real> <y:real> 
    => Point::new(x,y,None),
}
rect: (Point,Point) = {
  <p1:point> <p2:point>
    => (p1,p2)
}
// [DO xCount BY yCount STEP xStep yStep] 
step_pattern: StepPattern = {
  "DO" <x:integer> "BY" <y:integer> 
    "STEP" <xs:real> <ys:real>
    => StepPattern::new(x,y,xs,ys),
}
// [xOrigin yOrigin siteOrient [stepPattern]]
site_pattern: SitePattern = {
  <x:real> <y:real> <o:orient> <s:step_pattern?>
    => SitePattern::new(x,y,o,s),
}

