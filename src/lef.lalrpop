  <v:layer_antennadiffsidearearatio> <mut c:layer_routing_opts_> => vec_push![c,antennadiffsidearearatios,v],
  <v:layer_antennacumdiffsidearearatio> <mut c:layer_routing_opts_> => vec_push![c,antennacumdiffsidearearatios,v],
  <v:layer_antennadiffarearatio> <mut c:layer_routing_opts_> => vec_push![c,antennadiffarearatios,v],
  <v:layer_antennacumarearatio> <mut c:layer_routing_opts_> => vec_push![c,antennacumarearatios,v],
  <v:layer_antennacumdiffarearatio> <mut c:layer_routing_opts_> => vec_push![c,antennacumdiffarearatios,v],
  <v:layer_antennaareafactor> <mut c:layer_routing_opts_> => vec_push![c,antennaareafactors,v],
  <v:layer_antennasideareafactor> <mut c:layer_routing_opts_> => vec_push![c,antennasideareafactors,v],

  <v:layer_antennacumroutingpluscut> <mut c:layer_routing_opts_> =>  { c.antennacumroutingpluscut = Some(v) ; c },
  <v:layer_antennagateplusdiff> <mut c:layer_routing_opts_> =>  { c.antennagateplusdiff = Some(v) ; c },
  <v:layer_antennaareaminusdiff> <mut c:layer_routing_opts_> =>  { c.antennaareaminusdiff = Some(v) ; c },
  <v:layer_antennaareadiffreducepwl> <mut c:layer_routing_opts_> =>  { c.antennaareadiffreducepwl = Some(v) ; c },
  <v:property> <mut c:layer_routing_opts_> => vec_push![c,properties,v],
  <v:layer_accurrentdensity> <mut c:layer_routing_opts_> =>  { c.accurrentdensity = Some(v) ; c },
  <v:layer_dccurrentdensity> <mut c:layer_routing_opts_> =>  { c.dccurrentdensity = Some(v) ; c },
  () => <LayerRoutingOpts as std::default::Default>::default(),
  ! => panic_with_context!("error parsing layer routing opts", <>),
};
layer_routing_opts: LayerRoutingOpts = {
  <mut o1:layer_routing_opts_>
  <v:layer_routing_spacingtable> 
  <o2:layer_routing_opts_>
    => { 
      o1.copy(o2);
      o1.spacingtable = Some(v);
      o1 
    },
  <o1:layer_routing_opts_> => o1
}
layer_routing: LayerRouting = {
  "LAYER" <n:identifier> comment_opt
  "TYPE" "ROUTING" semicolon 
    <o:layer_routing_opts>
   <cn:end_name> 
    => LayerRouting::new(n,o,cn),
};

////////////////////////////////////////////////////////////////////////////////
//                                                                            //
//  End Layer Routing                                                         //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

layer_opts: LayerOpts = {
  <v:mask> <mut c:layer_opts> => { c.mask = Some(v); c },
  <v:layer_direction> <mut c:layer_opts> => { c.direction = Some(v); c },
  <v:layer_pitch> <mut c:layer_opts> => { c.pitch = Some(v); c },
  <v:layer_width> <mut c:layer_opts> => { c.width = Some(v); c },
  <v:layer_offset> <mut c:layer_opts> => { c.offset = Some(v); c },
  <v:layer_diagwidth> <mut c:layer_opts> => { c.diagwidth = Some(v); c },
  <v:layer_diagpitch> <mut c:layer_opts> => { c.diagpitch = Some(v); c },
  <v:layer_diagspacing> <mut c:layer_opts> => { c.diagspacing = Some(v); c },
  <v:layer_diagminedgelength> <mut c:layer_opts> => { c.diagminedgelength = Some(v); c },
  <v:layer_area> <mut c:layer_opts> => { c.area = Some(v); c },
  <v:layer_minsize> <mut c:layer_opts> => { c.minsize = Some(v); c },

  <v:layer_cut_spacing> <mut c:layer_opts> => vec_push![c,spacings,v],
  <v:layer_cut_spacingtable> <mut c:layer_opts> => set_opt![c,spacingtable,v],

  <v:layer_wireextension> <mut c:layer_opts> => { c.wireextension = Some(v); c },
  <v:layer_minimumcut> <mut c:layer_opts> => { c.minimumcut = Some(v); c },
  <v:layer_maxwidth> <mut c:layer_opts> => { c.maxwidth = Some(v); c },
  <v:layer_minwidth> <mut c:layer_opts> => { c.minwidth = Some(v); c },
  <v:layer_minstep> <mut c:layer_opts> => { c.minstep = Some(v); c },
  <v:layer_minenclosedarea> <mut c:layer_opts> => { c.minenclosedarea = Some(v); c },
  <v:layer_protrusionwidth> <mut c:layer_opts> => { c.protrusionwidth = Some(v); c },
  <v:layer_routing_resistance> <mut c:layer_opts> => { c.resistance = Some(v); c },
  <v:layer_routing_capacitance> <mut c:layer_opts> => { c.capacitance = Some(v); c },
  <v:layer_height> <mut c:layer_opts> => { c.height = Some(v); c },
  <v:layer_thickness> <mut c:layer_opts> => { c.thickness = Some(v); c },
  <v:layer_shrinkage> <mut c:layer_opts> => { c.shrinkage = Some(v); c },
  <v:layer_capmultiplier> <mut c:layer_opts> => { c.capmultiplier = Some(v); c },
  <v:layer_edgecapacitance> <mut c:layer_opts> => { c.edgecapacitance = Some(v); c },
  <v:layer_minimumdensity> <mut c:layer_opts> => { c.minimumdensity = Some(v); c },
  <v:layer_maximumdensity> <mut c:layer_opts> => { c.maximumdensity = Some(v); c },
  <v:layer_densitycheckwindow> <mut c:layer_opts> => { c.densitycheckwindow = Some(v); c },
  <v:layer_densitycheckstep> <mut c:layer_opts> => { c.densitycheckstep = Some(v); c },
  <v:layer_fillactivespacing> <mut c:layer_opts> => { c.fillactivespacing = Some(v); c },

  <v:antennamodel> <mut c:layer_opts> => vec_push![c,antennamodels,v],
  <v:layer_antennaarearatio> <mut c:layer_opts> => vec_push![c,antennaarearatios,v],
  <v:layer_antennasidearearatio> <mut c:layer_opts> => vec_push![c,antennasidearearatios,v],
  <v:layer_antennacumsidearearatio> <mut c:layer_opts> => vec_push![c,antennacumsidearearatios,v],
  <v:layer_antennadiffsidearearatio> <mut c:layer_opts> => vec_push![c,antennadiffsidearearatios,v],
  <v:layer_antennacumdiffsidearearatio> <mut c:layer_opts> => vec_push![c,antennacumdiffsidearearatios,v],
  <v:layer_antennadiffarearatio> <mut c:layer_opts> => vec_push![c,antennadiffarearatios,v],
  <v:layer_antennacumarearatio> <mut c:layer_opts> => vec_push![c,antennacumarearatios,v],
  <v:layer_antennacumdiffarearatio> <mut c:layer_opts> => vec_push![c,antennacumdiffarearatios,v],
  <v:layer_antennaareafactor> <mut c:layer_opts> => vec_push![c,antennaareafactors,v],
  <v:layer_antennasideareafactor> <mut c:layer_opts> => vec_push![c,antennasideareafactors,v],

  <v:layer_antennacumroutingpluscut> <mut c:layer_opts> =>  { c.antennacumroutingpluscut = Some(v) ; c },
  <v:layer_antennagateplusdiff> <mut c:layer_opts> =>  { c.antennagateplusdiff = Some(v) ; c },
  <v:layer_antennaareaminusdiff> <mut c:layer_opts> =>  { c.antennaareaminusdiff = Some(v) ; c },
  <v:layer_antennaareadiffreducepwl> <mut c:layer_opts> =>  { c.antennaareadiffreducepwl = Some(v) ; c },
  <v:property> <mut c:layer_opts> => vec_push![c,properties,v],
  <v:layer_accurrentdensity> <mut c:layer_opts> =>  { c.accurrentdensity = Some(v) ; c },
  <v:layer_dccurrentdensity> <mut c:layer_opts> =>  { c.dccurrentdensity = Some(v) ; c },
  () => <LayerOpts as std::default::Default>::default(),
  ! => panic_with_context!("error parsing layer opts", <>),
};


layer: Layer = {
  layer_cut => Layer::Cut(<>),
  layer_implant => Layer::Implant(<>),
  layer_masterslice_overlap => Layer::MasterSlice(<>),
  layer_routing => Layer::Routing(<>),
};



