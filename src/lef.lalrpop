  "BUMP" => MacroPinPortClass::BUMP,
  "bump" => MacroPinPortClass::BUMP,
}
macro_pin_port_class: MacroPinPortClass = {
  "CLASS" <v:macro_pin_port_class_enum> semicolon => v,
  "class" <v:macro_pin_port_class_enum> semicolon => v,
