stack: bool = {
  "STACK" => true,
};
layer_cut_spacing_adjacentcuts_exceptsamepgnet : bool = {
  "EXCEPTSAMEPGNET" => true,
};
layer_cut_spacing_enum: LayerCutSpacingEnum = {
  "LAYER" <s:identifier> <ls:stack?> => LayerCutSpacingEnum::LAYER(LayerCutSpacingLayer::new(s,ls)),
  "ADJACENTCUTS" <n:integer> "WITHIN" <w:real> <e:layer_cut_spacing_adjacentcuts_exceptsamepgnet?>
    => LayerCutSpacingEnum::ADJACENTCUT(LayerCutSpacingAdjacentCut::new(n,w,e)),
  "PARALLELOVERLAP" => LayerCutSpacingEnum::PARALLELOVERLAP,
  "AREA" <n:real> => LayerCutSpacingEnum::AREA(n),
};
layer_cut_spacing: LayerCutSpacing = {
  "SPACING" <n:real>
    <ctc:centertocenter?>
    <s:samenet?>
    <opts:layer_cut_spacing_enum?>
  semicolon 
    => LayerCutSpacing::new(n,ctc,s,opts)
};

