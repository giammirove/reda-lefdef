//                                                                            //
//  Site                                                                      //
//                                                                            //
////////////////////////////////////////////////////////////////////////////////

// SITE siteName
//     CLASS {PAD | CORE} ;
//     [SYMMETRY {X | Y | R90} ... ;]
//     [ROWPATTERN {previousSiteName siteOrient} ... ;]
//     SIZE width BY height ; 
// END siteName

site_class: SiteClass = {
  "PAD" => SiteClass::PAD,
  "pad" => SiteClass::PAD,
  "CORE" => SiteClass::CORE,
  "core" => SiteClass::CORE,
}

site_opts: SiteOpts = {
  "CLASS" <c:site_class> semicolon <mut o:site_opts> => set_opt![o,class,c],
  "SIZE" <w:real> "BY" <h:real> semicolon <mut o:site_opts> => set_opt![o,size,Size::new(w,h)],
  <s:symmetry> <mut o:site_opts> => set_opt![o,symmetries,s],
  <r:rowpattern> <mut o:site_opts> => set_opt![o,rowpattern,r],
  () => <SiteOpts as std::default::Default>::default()
}

site: Site = {
  "SITE" <n:identifier> 
    <o:site_opts>
    "END" <chk_n:identifier>
      => Site::new(n,o,chk_n),
}

